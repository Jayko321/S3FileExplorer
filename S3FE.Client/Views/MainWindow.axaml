<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:S3FE.Client.ViewModels"
        xmlns:dto="using:S3FE.Shared.DTOs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="760"
        x:Class="S3FE.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="S3 File Explorer"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#141218">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1D1B20" />
            <Setter Property="Foreground" Value="#E6E1E5" />
            <Setter Property="BorderBrush" Value="#938F99" />
            <Setter Property="CaretBrush" Value="#D0BCFF" />
            <Setter Property="SelectionBrush" Value="#4F378B" />
        </Style>

        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#211F26" />
            <Setter Property="Foreground" Value="#E6E1E5" />
            <Setter Property="BorderBrush" Value="#D0BCFF" />
        </Style>

        <Style Selector="TextBox:focus">
            <Setter Property="Background" Value="#211F26" />
            <Setter Property="Foreground" Value="#E6E1E5" />
            <Setter Property="BorderBrush" Value="#D0BCFF" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#D0BCFF" />
            <Setter Property="Foreground" Value="#381E72" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#EADDFF" />
            <Setter Property="Foreground" Value="#21005D" />
        </Style>

        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="#B69DF8" />
            <Setter Property="Foreground" Value="#21005D" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#4A4458" />
            <Setter Property="Foreground" Value="#EADDFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#5E566D" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.destructive">
            <Setter Property="Background" Value="#8C1D18" />
            <Setter Property="Foreground" Value="#FFDAD6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.destructive:pointerover">
            <Setter Property="Background" Value="#BA1A1A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.tab-close">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CAC4D0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <Style Selector="Button.tab-close:pointerover">
            <Setter Property="Background" Value="#5E566D" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#E6E1E5" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TabItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="TabStripItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="24" RowSpacing="20">
        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="28"
                Background="#211F26"
                BorderBrush="#49454F"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="S3 File Explorer"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#E6E1E5" />
                        <TextBlock Text="Connect to a local MinIO instance and browse S3-compatible storage."
                                   FontSize="14"
                                   Foreground="#CAC4D0" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="14,8"
                            CornerRadius="18"
                            Background="#4A4458"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   Foreground="#EADDFF"
                                   TextWrapping="Wrap"
                                   MaxWidth="420" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="2*,*,*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="14"
                      RowSpacing="8">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Endpoint"
                               Foreground="#CAC4D0" />
                    <TextBox Grid.Row="1"
                             Grid.Column="0"
                             Text="{Binding Endpoint}"
                             PlaceholderText="http://localhost:9000" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="Access key"
                               Foreground="#CAC4D0" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding AccessKey}"
                             PlaceholderText="minioadmin" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Secret key"
                               Foreground="#CAC4D0" />
                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             Text="{Binding SecretKey}"
                             PasswordChar="*"
                             PlaceholderText="minioadmin" />

                    <Button Grid.Row="1"
                            Grid.Column="3"
                            Classes="primary"
                            Content="Connect"
                            Command="{Binding ConnectCommand}"
                            MinWidth="130"
                            Padding="18,8"
                            HorizontalContentAlignment="Center"
                            VerticalAlignment="Stretch" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="280,*"
              ColumnSpacing="20">
            <Border Grid.Column="0"
                    Padding="20"
                    CornerRadius="28"
                    Background="#211F26"
                    BorderBrush="#49454F"
                    BorderThickness="1"
                    IsVisible="{Binding IsConnected}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,0,0,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Buckets"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#E6E1E5" />
                            <TextBlock Text="Available storage buckets"
                                       FontSize="13"
                                       Foreground="#CAC4D0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Classes="secondary"
                                    Content="Add bucket"
                                    Command="{Binding OpenCreateBucketPopupCommand}"
                                    HorizontalContentAlignment="Center" />
                            <Button Classes="destructive"
                                    Content="Delete"
                                    Command="{Binding DeleteSelectedBucketCommand}"
                                    HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Buckets}"
                             SelectedItem="{Binding SelectedBucket}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:BucketItemViewModel">
                                <Border Padding="14,12"
                                        Margin="0,4"
                                        CornerRadius="18"
                                        Background="#2B2930">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="10"
                                                Height="10"
                                                CornerRadius="5"
                                                Background="#D0BCFF"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding IsSelected}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#E6E1E5"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="20"
                    CornerRadius="28"
                    Background="#211F26"
                    BorderBrush="#49454F"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Browser"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#E6E1E5" />
                            <TextBlock Text="Open a bucket tab to inspect files at the bucket root."
                                       FontSize="13"
                                       Foreground="#CAC4D0"
                                       IsVisible="{Binding IsConnected}" />
                        </StackPanel>

                        <ProgressBar Grid.Column="1"
                                     Width="180"
                                     Height="6"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsConnecting}"
                                     VerticalAlignment="Center" />
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="24"
                            Background="#1D1B20"
                            BorderBrush="#49454F"
                            BorderThickness="1"
                            IsVisible="{Binding !IsConnected}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="420"
                                    Spacing="12">
                            <TextBlock Text="Connect to MinIO"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="#E6E1E5"
                                       TextAlignment="Center" />
                            <TextBlock Text="After connecting, buckets will appear on the left and each bucket will open as a tab on the right."
                                       FontSize="14"
                                       Foreground="#CAC4D0"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="1"
                                ItemsSource="{Binding BucketTabs}"
                                SelectedItem="{Binding SelectedBucketTab}"
                                Background="Transparent"
                                IsVisible="{Binding IsConnected}">
                        <TabControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:BucketTabViewModel">
                                <Grid>
                                    <Border Padding="14,6"
                                            Margin="2,0"
                                            CornerRadius="10"
                                            Background="#2B2930"
                                            IsVisible="{Binding !IsSelected}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding BucketName}"
                                                       Foreground="#CAC4D0"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Classes="tab-close"
                                                    Content="×"
                                                    Command="{Binding CloseCommand}" />
                                        </Grid>
                                    </Border>

                                    <Border Padding="14,6"
                                            Margin="2,0"
                                            CornerRadius="10"
                                            Background="#6750A4"
                                            IsVisible="{Binding IsSelected}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding BucketName}"
                                                       Foreground="#FFFFFF"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Classes="tab-close"
                                                    Content="×"
                                                    Command="{Binding CloseCommand}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:BucketTabViewModel">
                                <Grid RowDefinitions="Auto,*" RowSpacing="14" Margin="0,18,0,0">
                                    <Border Grid.Row="0"
                                            Padding="16,10"
                                            CornerRadius="20"
                                            Background="#4A4458">
                                        <Grid ColumnDefinitions="*,120,190" ColumnSpacing="16">
                                            <TextBlock Grid.Column="0"
                                                       Text="Object key"
                                                       FontWeight="SemiBold"
                                                       Foreground="#EADDFF" />
                                            <TextBlock Grid.Column="1"
                                                       Text="Size"
                                                       FontWeight="SemiBold"
                                                       Foreground="#EADDFF" />
                                            <TextBlock Grid.Column="2"
                                                       Text="Last modified"
                                                       FontWeight="SemiBold"
                                                       Foreground="#EADDFF" />
                                        </Grid>
                                    </Border>

                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding Files}"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="dto:S3ObjectDTO">
                                                <Border Padding="16,12"
                                                        Margin="0,4"
                                                        CornerRadius="18"
                                                        Background="#2B2930">
                                                    <Grid ColumnDefinitions="*,120,190" ColumnSpacing="16">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Key}"
                                                                   Foreground="#E6E1E5"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Size}"
                                                                   Foreground="#CAC4D0" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding LastModified}"
                                                                   Foreground="#CAC4D0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#AA000000"
                IsVisible="{Binding IsCreateBucketPopupOpen}">
            <Border Width="420"
                    Padding="24"
                    CornerRadius="24"
                    Background="#211F26"
                    BorderBrush="#49454F"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Create bucket"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#E6E1E5" />
                        <TextBlock Text="Enter a new bucket name. Bucket names should be lowercase and S3-compatible."
                                   FontSize="13"
                                   Foreground="#CAC4D0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBox Text="{Binding NewBucketName}"
                             PlaceholderText="new-bucket-name" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Classes="secondary"
                                Content="Cancel"
                                Command="{Binding CancelCreateBucketCommand}" />
                        <Button Classes="primary"
                                Content="Create"
                                Command="{Binding AddBucketCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
